# Binance API Keys (testnet)
BINANCE_API_KEY=your_testnet_api_key_here
BINANCE_API_SECRET=your_testnet_api_secret_here

# Trading parameters
SYMBOL=BTCUSDT
INTERVAL=15m
QUANTITY=0.001

# Risk management
STOP_LOSS_PCT=2.0
TAKE_PROFIT_PCT=4.0

# Balance management
MIN_USDT_BALANCE=10.0    # solde minimum en USDT pour executer un trade
TRADE_BALANCE_PCT=0.9    # % du solde USDT utilise par trade (0.9 = 90%)

# Trailing Stop Loss
TRAILING_SL_ENABLED=true
TRAILING_SL_PCT=1.5      # SL monte de 1.5% sous le prix max atteint

# Multi-crypto
MULTI_CRYPTO=true
MAX_POSITIONS=10         # nombre max de cryptos tradees en meme temps
SCAN_INTERVAL=300        # scanner toutes les 5 minutes (300 secondes)

# Dashboard
DASHBOARD_PASSWORD=changez_ce_mot_de_passe  # laisser vide = pas de mot de passe (local only)

# Logging
LOG_LEVEL=INFO
